# Ambil data dari internet pakai get(url)
# Kalau gagal (tidak ada koneksi, URL salah, server error),
# get() melempar error yang bisa ditangkap pakai try/catch —
# sama seperti error lain di Vidyax.

try:
    print "Mengambil data..."
    hasil: get("https://api.github.com/zen")
    print hasil
    data: get("https://example.com")
    print "Panjang halaman: " + len(data) + " karakter"
catch e:
    print "Gagal ambil data: " + e
    print "Program tetap lanjut dengan aman."
